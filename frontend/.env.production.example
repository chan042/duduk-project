# Copy this file to .env.production and replace the placeholder values.
# Mobile builds intentionally fail until NEXT_PUBLIC_API_URL points to a real HTTPS backend.

NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WEB_URL=https://app.example.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_KAKAO_REST_API_KEY=your-kakao-rest-api-key
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-js-key
